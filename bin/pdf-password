#!/usr/bin/env bash
# Manage PDF passwords stored in the macOS Keychain.
# Passwords never touch disk or git — only the encrypted Keychain.

set -euo pipefail

# shellcheck source=lib/keychain.sh
source "${HOME}/.local/bin/lib/keychain.sh"

readonly SCRIPT_NAME="$(basename "$0")"

usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} <command> [name]

Commands:
  add [name]       Store a password in Keychain (prompts securely; default name: default)
  list             List stored password names (not the passwords themselves)
  remove <name>    Remove a stored password from Keychain
  trust            Allow Finder/Automator to read stored passwords (run after install)
  test             Verify Keychain access works

Passwords are stored in the macOS Keychain under service "${KEYCHAIN_SERVICE}".
This is the recommended location on Mac: encrypted, backed up with iCloud Keychain
if enabled, and never committed to git.

Examples:
  ${SCRIPT_NAME} add work
  ${SCRIPT_NAME} list
  ${SCRIPT_NAME} remove work
  ${SCRIPT_NAME} trust
EOF
}

cmd_add() {
  local name="${1:-default}"
  if [[ "$name" == -* ]]; then
    echo "error: invalid password name: $name" >&2
    exit 1
  fi

  echo -n "Enter password for '${name}': "
  read -rs password
  echo
  if [[ -z "$password" ]]; then
    echo "error: password cannot be empty" >&2
    exit 1
  fi

  echo -n "Confirm password: "
  read -rs confirm
  echo
  if [[ "$password" != "$confirm" ]]; then
    echo "error: passwords do not match" >&2
    exit 1
  fi

  keychain_update_trust "$name" "$password"
  echo "Stored password '${name}' in Keychain."
}

cmd_trust() {
  if keychain_refresh_trust; then
    echo "Updated Keychain access for Finder and Automator."
  else
    echo "No stored passwords found. Run: ${SCRIPT_NAME} add"
    exit 1
  fi
}

cmd_list() {
  local accounts
  accounts="$(keychain_accounts || true)"
  if [[ -z "$accounts" ]]; then
    echo "No passwords stored. Run: ${SCRIPT_NAME} add"
    return 0
  fi
  echo "Stored password names:"
  echo "$accounts" | sed 's/^/  - /'
}

cmd_remove() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "error: password name required" >&2
    usage
    exit 1
  fi

  if security delete-generic-password -a "$name" -s "$KEYCHAIN_SERVICE" 2>/dev/null; then
    accounts_unregister "$name"
    echo "Removed password '${name}' from Keychain."
  else
    echo "error: no password named '${name}' found" >&2
    exit 1
  fi
}

cmd_test() {
  local accounts
  accounts="$(keychain_accounts || true)"
  if [[ -z "$accounts" ]]; then
    echo "No passwords in Keychain yet. Run: ${SCRIPT_NAME} add"
    exit 1
  fi
  local name
  name="$(echo "$accounts" | head -1)"
  if security find-generic-password -a "$name" -s "$KEYCHAIN_SERVICE" -w >/dev/null 2>&1; then
    echo "Keychain access OK (verified account: ${name})."
  else
    echo "error: could not read password from Keychain. Run: ${SCRIPT_NAME} trust" >&2
    exit 1
  fi
}

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    add)    cmd_add "$@" ;;
    list)   cmd_list ;;
    remove) cmd_remove "$@" ;;
    trust)  cmd_trust ;;
    test)   cmd_test ;;
    -h|--help|help|"")
      usage
      [[ -n "$command" ]] || exit 0
      ;;
    *)
      echo "error: unknown command: $command" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
